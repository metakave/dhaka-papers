beta.dhakapapers.com, dhakapaper.com, www.dhakapaper.com, dhakapapers.com, www.dhakapapers.com {
    # 1. Backend API (Path: /api/*)
    handle /api* {
        reverse_proxy news_portal_backend:8080
    }

    # 2. CMS (Path: /admin/*)
    handle /admin* {
        reverse_proxy news_portal_cms:3000
    }

    # 3. Frontend (Default - everything else)
    handle {
        reverse_proxy news_portal_frontend:3000
    }
}
