# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=news_portal
DB_PORT=5432

# -----------------------------------------------------------------------------
# BACKEND API CONFIGURATION
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://localhost:5432/news_portal?sslmode=disable
BACKEND_PORT=8080
PORT=8080

JWT_SECRET=supersecretlocalonly
APP_ENV=development
INITIAL_ADMIN_NAME="Admin User"
INITIAL_ADMIN_EMAIL="admin@news.com"
INITIAL_ADMIN_PASSWORD="password123"

# Auth Configuration
AUTH_COOKIE_SECURE=false

# CORS: The domains allowed to talk to the API. 
# Use localhost for dev, and real domains (https://news.com) for production.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://beta.dhakapapers.com,https://dhakapaper.com,https://www.dhakapaper.com,https://dhakapapers.com,https://www.dhakapapers.com

# -----------------------------------------------------------------------------
# CLOUDFLARE R2 STORAGE (Required for Images)
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=dd8670954263a64080507d148916289f
R2_ACCESS_KEY_ID=f2aeeb11c588970750d9acfaf8342e2e
R2_SECRET_ACCESS_KEY=db6d3c19d2840c7d8b3507a70f927ef3f640f8f1a1e4f5d14470cf224abcec3e
R2_BUCKET_NAME=dhakapapers
R2_PUBLIC_URL=https://pub-a6f30b17c688489f85618f1bdd18fc81.r2.dev

# -----------------------------------------------------------------------------
# FRONTEND & CMS CONFIGURATION
# -----------------------------------------------------------------------------
FRONTEND_PORT=3000
CMS_PORT=3001

# The API URL that the BROWSER uses to talk to the backend.
# Use localhost:8080 for dev, and api.news.com for production.
NEXT_PUBLIC_API_URL=/api/v1
INTERNAL_API_URL=http://backend:8080/api/v1
NEXT_PUBLIC_BASE_URL=https://dhakapapers.com
